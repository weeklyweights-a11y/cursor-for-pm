# Database
POSTGRES_USER=your_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cursor_for_pms
DATABASE_URL=postgresql://your_user:change_me@db:5432/cursor_for_pms

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Slack (Phase 2)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# CSV ingestion
MAX_SYNC_CSV_ROWS=100
MAX_CSV_FILE_SIZE_MB=10

# Encryption (Fernet; base64 32-byte key for Slack tokens)
ENCRYPTION_KEY=

# JWT
JWT_SECRET=your-long-random-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
ENVIRONMENT=development
DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# LLM (Phase 3: extraction)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Phase 6: Chat (conversational layer)
CHAT_LLM_MODEL=llama3.2:3b
CHAT_MAX_HISTORY=20
CHAT_MAX_RAG_ITEMS=20
CHAT_MAX_RESPONSE_TOKENS=1500
CHAT_TEMPERATURE=0.3
CHAT_TIMEOUT_SECONDS=60

# Phase 7: Evidence briefs
BRIEF_LLM_MODEL=llama3.2:3b
BRIEF_MAX_SECTION_TOKENS=1000
BRIEF_TEMPERATURE=0.4
BRIEF_TIMEOUT_SECONDS=60

# Phase 8: Agent-ready specs
SPEC_LLM_MODEL=llama3.2:3b
SPEC_MAX_SECTION_TOKENS=1500
SPEC_TEMPERATURE=0.3
SPEC_TIMEOUT_SECONDS=60
